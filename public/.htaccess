# Gadaa Securities Dealer - React (Vite) build
# Place this file inside the same folder as index.html on your cPanel
# hosting (e.g. public_html/ or public_html/your-subfolder/).
# It makes client-side routing (React Router) work correctly so that
# refreshing a URL like /about or /contact doesn't 404.

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # If the request is for a real file or folder, serve it directly
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Otherwise, send everything to index.html so React Router can handle it
  RewriteRule ^ index.html [L]
</IfModule>

# Optional: basic caching for static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpg "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType text/css "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
</IfModule>
